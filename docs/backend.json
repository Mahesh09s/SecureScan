
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user data and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "analyst", "viewer"] },
        "status": { "type": "string", "enum": ["Active", "Suspended", "Locked"] },
        "mfaEnabled": { "type": "boolean" },
        "mfaMethod": { "type": "string", "enum": ["TOTP", "Email", "SMS"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "loginAttempts": { "type": "number" },
        "passwordLastChanged": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Session": {
      "title": "Session",
      "description": "Active user sessions for management",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "device": { "type": "string" },
        "browser": { "type": "string" },
        "os": { "type": "string" },
        "ipAddress": { "type": "string" },
        "location": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "isCurrent": { "type": "boolean" }
      },
      "required": ["userId", "device", "ipAddress"]
    },
    "ApiKey": {
      "title": "ApiKey",
      "description": "Machine-to-machine access keys",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "prefix": { "type": "string" },
        "lastFour": { "type": "string" },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "revoked": { "type": "boolean" }
      },
      "required": ["userId", "name", "prefix"]
    },
    "Asset": {
      "title": "Asset",
      "description": "A security target to be scanned",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string", "enum": ["Website", "Domain", "Server", "IP"] },
        "environment": { "type": "string" },
        "status": { "type": "string", "enum": ["Healthy", "Vulnerable", "Scanning"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "target", "type", "ownerId"]
    },
    "Scan": {
      "title": "Scan",
      "description": "An execution of a scanning tool",
      "type": "object",
      "properties": {
        "assetId": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed", "Failed"] },
        "progress": { "type": "number" },
        "logs": { "type": "array", "items": { "type": "string" } },
        "vulnerabilitiesFound": { "type": "number" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["assetId", "type", "status", "ownerId"]
    },
    "Vulnerability": {
      "title": "Vulnerability",
      "description": "A detected security finding",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low", "Info"] },
        "description": { "type": "string" },
        "impact": { "type": "string" },
        "recommendation": { "type": "string" },
        "assetId": { "type": "string" },
        "assetName": { "type": "string" },
        "scanId": { "type": "string" },
        "cve": { "type": "string" },
        "cvss": { "type": "number" },
        "evidence": { "type": "string" },
        "source": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "severity", "assetId", "ownerId"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Record of sensitive system actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "resource": { "type": "string" },
        "details": { "type": "string" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error", "success"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile" },
    "/users/{userId}/sessions/{sessionId}": { "schema": "Session" },
    "/users/{userId}/apiKeys/{keyId}": { "schema": "ApiKey" },
    "/assets/{assetId}": { "schema": "Asset" },
    "/scans/{scanId}": { "schema": "Scan" },
    "/vulnerabilities/{vulnId}": { "schema": "Vulnerability" },
    "/auditLogs/{logId}": { "schema": "AuditLog" },
    "/notifications/{notifId}": { "schema": "Notification" },
    "/users/{userId}/chatHistory/{messageId}": { "schema": "ChatMessage" }
  }
}
